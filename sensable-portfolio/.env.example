RENDERER_WS_URL=ws://127.0.0.1:7777
RENDERER_ENABLED=true
DEBUG_SSE_ENABLED=false
DB_URL=sqlite+aiosqlite:///./sensable.db
LANGSMITH_API_KEY=
OPENAI_API_KEY=

# LLM provider: stub (default; offline), ollama, anthropic
LLM_PROVIDER=stub

# Ollama (local OR Ollama Cloud — :cloud tags route through your local daemon
# after `ollama signin`)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=kimi-k2:1t-cloud

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
